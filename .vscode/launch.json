{
    "version": "0.2.0",
    "configurations": [
        
        {
            "name": "Python Debugger: opensteuerauszug",
            "type": "debugpy",
            "request": "launch",
            "module": "opensteuerauszug.steuerauszug",
            "console": "integratedTerminal",
            "python": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
            "args": ["c:\\path_to_ibkr\\All2025.xml", "--importer", "ibkr", "--broker", "ibkr", "--tax-year", "2025", "--tax-calculation-level", "broker_fillin", "--skip-broker-payments-from-reconciliation", "--log-file", "C:\\path_to_log\\Steuerauszug IBKR 2025 mit Vergleich.log", "-o", "C:\\path_to_pdf\\Steuerauszug IBKR 2025 mit Vergleich.pdf"],
            "env": {
                "PYTHONPATH": "${workspaceFolder}\\.venv"
            },
            "cwd": "${workspaceRoot}",
            "justMyCode": false
        },
        {
            "name": "Python Debugger: opensteuerauszug kursliste",
            "type": "debugpy",
            "request": "launch",
            "module": "opensteuerauszug.kursliste",
            "console": "integratedTerminal",
            "python": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
            "args": ["download", "--year", "2025"],
            "env": {
                "PYTHONPATH": "${workspaceFolder}\\.venv"
            },
            "cwd": "${workspaceRoot}",
            "justMyCode": false
        }
    ]
}
